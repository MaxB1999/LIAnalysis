# LinkedIn Content Generator — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Gmail SMTP ───────────────────────────────────────────────────────────────

# The Gmail address you want to send posts FROM.
GMAIL_USER=you@gmail.com

# A Google App Password — NOT your regular Gmail password.
# How to generate one:
#   1. Go to your Google Account → Security
#   2. Enable 2-Step Verification if not already on
#   3. Search for "App Passwords" in the Security page
#   4. Select app: Mail, device: Other (custom name e.g. "LinkedIn Bot")
#   5. Copy the 16-character password shown and paste it here
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── Recipient ────────────────────────────────────────────────────────────────

# The email address that receives the generated LinkedIn post each morning.
RECIPIENT_EMAIL=you@example.com
